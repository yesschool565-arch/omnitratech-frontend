# Backend Environment Configuration

# Server Configuration
PORT=3001
NODE_ENV=production

# Database
# The app uses JSON file-based storage at backend/data/database.json
# No additional database configuration needed

# CORS Configuration
# Update this to match your frontend URL
CORS_ORIGIN=http://localhost:5175

# API Configuration
API_TIMEOUT=30000

# NOTE FOR RENDER DEPLOYMENT:
# 1. PORT will be automatically set by Render, no need to configure
# 2. CORS_ORIGIN should be set to your Vercel frontend URL
# 3. Example: https://your-app.vercel.app
# 4. NODE_ENV is automatically set to 'production' on Render
