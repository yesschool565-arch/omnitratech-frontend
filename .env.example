# Frontend Environment Configuration

# Backend API URL
# Development: http://localhost:3001/api (uses Vite proxy)
# Production: https://your-render-backend.onrender.com/api
VITE_API_URL=http://localhost:3001/api

# Gemini API Key (optional, for AI features)
GEMINI_API_KEY=

# NOTE FOR VERCEL DEPLOYMENT:
# 1. Set VITE_API_URL to your Render backend URL in Vercel Environment Variables
# 2. Example: https://your-app.onrender.com/api
# 3. The /api prefix is required for all API requests
